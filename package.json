{
  "name": "semantic-release-cmyr-config",
  "version": "1.0.2",
  "description": "草梅友仁自定义的 semantic-release 配置",
  "author": "CaoMeiYouRen",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "cross-env NODE_ENV=production eslint . --fix --ext .ts,.js,.cjs,.mjs",
    "release": "semantic-release",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:tsup": "cross-env NODE_ENV=development tsdown --watch",
    "start": "node ./dist/index",
    "start:tsx": "cross-env NODE_ENV=production tsx src/index.ts",
    "commit": "cz",
    "prepare": "husky",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-cmyr-config": "^3.0.0",
    "conventional-changelog-writer": "^9.1.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^26.0.1",
    "commitizen": "^4.3.1",
    "commitlint": "^20.1.0",
    "commitlint-config-cmyr": "^1.0.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.39.1",
    "eslint-config-cmyr": "^2.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "semantic-release": ">=24"
  },
  "peerDependenciesMeta": {
    "semantic-release": {
      "optional": false
    }
  },
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [
    "semantic-release",
    "changelog",
    "release",
    "publish",
    "typescript"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/semantic-release-cmyr-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/semantic-release-cmyr-config.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/semantic-release-cmyr-config/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
